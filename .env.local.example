# OpenAI API key (optional if GEMINI_API_KEY is set; app prefers OpenAI then falls back to Gemini)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: text-only generation model. Defaults to gpt-5-mini.
OPENAI_MODEL=gpt-5-mini

# Google AI Studio API key (optional fallback for JSON question generation when OpenAI fails or is unset)
GEMINI_API_KEY=

# Optional: Gemini model for JSON generation. Defaults to gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash

# Optional: sampling temperature for JSON question generation (OpenAI / Gemini). Omit for provider default.
# OPENAI_TEMPERATURE=0.7
# GEMINI_TEMPERATURE=0.7

# Optional: run a second LLM pass to review/fix generated JSON (higher cost, often better consistency).
# AI_QUESTION_REVIEW_ENABLED=true

# Optional: vision-capable model used by scripts/build-exam-json.mjs.
# Must support image inputs. Defaults to gpt-5.
OPENAI_VISION_MODEL=gpt-5
