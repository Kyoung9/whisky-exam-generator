# OpenAI API key (required)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: text-only generation model. Defaults to gpt-5-mini.
OPENAI_MODEL=gpt-5-mini

# Optional: vision-capable model used by scripts/build-exam-json.mjs.
# Must support image inputs. Defaults to gpt-5.
OPENAI_VISION_MODEL=gpt-5
